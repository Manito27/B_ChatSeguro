DEBUG=False
SECRET_KEY=troque-esta-chave-por-uma-segura
ALLOWED_HOSTS=localhost,127.0.0.1,seu-backend.onrender.com
TIME_ZONE=Africa/Maputo

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
# Use origens sem barra final.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://chatsegur.netlify.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://chatsegur.netlify.app

DB_CONN_MAX_AGE=60
# Em producao, defina DATABASE_URL com uma URL PostgreSQL valida
# ou remova a variavel por completo; nao deixe valor vazio ou placeholder.
DATABASE_URL=postgresql://postgres:senha@localhost:5432/chatseguro?sslmode=require

# Bootstrap do admin do Django no deploy.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@exemplo.com
DJANGO_SUPERUSER_PASSWORD=troque-esta-senha-admin
DJANGO_SUPERUSER_RESET_PASSWORD=False

# Alternativa ao DATABASE_URL:
# POSTGRES_DB=chatseguro
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=sua-senha
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require
