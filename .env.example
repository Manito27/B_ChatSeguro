DEBUG=False
SECRET_KEY=troque-esta-chave-por-uma-segura
ALLOWED_HOSTS=localhost,127.0.0.1,seu-backend.onrender.com
TIME_ZONE=Africa/Maputo

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
# Use origens sem barra final.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://chatsegur.netlify.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://chatsegur.netlify.app

DB_CONN_MAX_AGE=60
# Em producao, defina DATABASE_URL com a URI PostgreSQL do Aiven
# ou remova a variavel por completo; nao deixe valor vazio ou placeholder.
DATABASE_URL=postgresql://avnadmin:sua-senha@pg-seu-servico.aivencloud.com:12345/defaultdb?sslmode=require
# Para validacao mais forte do certificado no Aiven, envie o CA como Secret File no Render.
# POSTGRES_SSLMODE=verify-full
# POSTGRES_SSLROOTCERT=/etc/secrets/aiven-ca.pem
# POSTGRES_APPLICATION_NAME=chatseguro

# Bootstrap do admin do Django no deploy.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@exemplo.com
DJANGO_SUPERUSER_PASSWORD=troque-esta-senha-admin
DJANGO_SUPERUSER_RESET_PASSWORD=False

# Opcional: bootstrap de varios utilizadores do Django via JSON.
# Cada item aceita: username, email, password, is_staff, is_superuser,
# is_active e reset_password.
# DJANGO_BOOTSTRAP_USERS=[{"username":"admin2","email":"admin2@exemplo.com","password":"senha-forte","is_superuser":true},{"username":"ana","email":"ana@exemplo.com","password":"senha-ana","is_staff":false}]

# Alternativa ao DATABASE_URL:
# POSTGRES_DB=defaultdb
# POSTGRES_USER=avnadmin
# POSTGRES_PASSWORD=sua-senha
# POSTGRES_HOST=pg-seu-servico.aivencloud.com
# POSTGRES_PORT=12345
# POSTGRES_SSLMODE=require
# POSTGRES_SSLROOTCERT=/etc/secrets/aiven-ca.pem
